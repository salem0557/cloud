# انسخ هذا الملف إلى ‎.env وضع توكن البوت الخاص بك (من @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAAA-your-token-here

# --- الاشتراك المدفوع ---
# معرّف محادثتك أنت في تيليجرام (المشرف — دائم الصلاحية ويملك أوامر /approve /revoke /subs)
ADMIN_CHAT_ID=123456789
# طريقة التواصل التي تظهر للراغبين بالاشتراك
SUBSCRIBE_CONTACT=@your_username
# مدة الاشتراك الافتراضية بالأيام عند /approve بدون تحديد
DEFAULT_SUB_DAYS=30

# --- "وجهة نظر البوت" (ملخص أخبار + StockTwits لكل سهم مُرشَّح) ---
# مجاني: 1) افتح aistudio.google.com وسجّل دخول بحساب Google
#        2) اضغط "Get API key" وأنشئ مفتاحاً جديداً (بلا بطاقة ائتمان)
#        3) الصقه هنا. بدون هذا المفتاح يُعطَّل القسم تلقائياً بلا أي خطأ.
GEMINI_API_KEY=

# اختياري: تغيير الإعدادات الافتراضية
# FILTERS_REQUIRED=3        # عدد الفلاتر المطلوبة من أصل 4
# SCAN_INTERVAL=1h          # فريم الشموع
# MIN_PRICE=2               # استبعاد الأسهم تحت هذا السعر بالدولار
# MIN_AVG_VOLUME=30000      # استبعاد الأسهم قليلة السيولة
# RSI_OVERSOLD=30
