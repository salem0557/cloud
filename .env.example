# انسخ هذا الملف إلى ‎.env وضع توكن البوت الخاص بك (من @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAAA-your-token-here

# معرّف محادثتك أنت في تيليجرام (مصرّح لك دائماً، بلا حاجة لإدراجك في
# state.json's "approved"). أعضاء آخرون يُضافون يدوياً هناك فقط -- لا يوجد
# أمر لإضافتهم من داخل البوت.
ADMIN_CHAT_ID=123456789
# يظهر في رسالة الرفض لمن ليس ضمن الأعضاء المعتمدين
SUBSCRIBE_CONTACT=@your_username

# اختياري: تغيير الإعدادات الافتراضية (القائمة الكاملة في scanner/config.py)
# SESSION_TIMEOUT_SECONDS=300     # الحد الأقصى لطول أي جلسة فحص
# STOCKS_FILTERS_REQUIRED=3       # من أصل 4 فلاتر أسهم
# STOCKS_RSI_OVERSOLD=35
# CRYPTO_FILTERS_REQUIRED=2       # من أصل 3 فلاتر كريبتو
